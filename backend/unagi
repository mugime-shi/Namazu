#!/usr/bin/env bash
set -euo pipefail

# ── Defaults ─────────────────────────────────────────────────
DAYS=30
AREA=SE3
TRIALS=100

# ── Parse flags after subcommand ─────────────────────────────
HORIZON=3
TRAIN_DAYS=270

parse_flags() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --days)       DAYS="$2";       shift 2 ;;
            --area)       AREA="$2";       shift 2 ;;
            --trials)     TRIALS="$2";     shift 2 ;;
            --date)       TARGET_DATE="$2"; shift 2 ;;
            --horizon)    HORIZON="$2";    shift 2 ;;
            --train-days) TRAIN_DAYS="$2"; shift 2 ;;
            *) echo "Unknown flag: $1" >&2; exit 1 ;;
        esac
    done
}

# ── Subcommands ──────────────────────────────────────────────
cmd_fetch() {
    parse_flags "$@"
    python -m app.tasks.fetch_prices --area "$AREA"
}

cmd_backfill() {
    parse_flags "$@"
    python -m app.tasks.fetch_prices --backfill "$DAYS" --area "$AREA"
}

cmd_backfill_gen() {
    parse_flags "$@"
    python -m app.tasks.fetch_prices --backfill "$DAYS" --generation --area "$AREA"
}

cmd_backfill_load() {
    parse_flags "$@"
    python -m app.tasks.fetch_prices --backfill "$DAYS" --load-forecast --area "$AREA"
}

cmd_backfill_de() {
    parse_flags "$@"
    python -m app.tasks.fetch_prices --backfill "$DAYS" --de-price
}

cmd_backfill_gas() {
    parse_flags "$@"
    python -m app.tasks.fetch_prices --backfill "$DAYS" --gas-price
}

cmd_backfill_bal() {
    parse_flags "$@"
    python -m app.tasks.fetch_prices --backfill "$DAYS" --balancing --area "$AREA"
}

cmd_backtest() {
    parse_flags "$@"
    python -m scripts.run_backtest --days "$DAYS" --area "$AREA"
}

cmd_tune() {
    parse_flags "$@"
    python -m scripts.tune_hyperparams --trials "$TRIALS" --area "$AREA"
}

cmd_sweep() {
    parse_flags "$@"
    python -m scripts.sweep_train_window --test-days "$DAYS" --area "$AREA"
}

cmd_features() {
    parse_flags "$@"
    python -m scripts.build_feature_matrix --days "$DAYS" --area "$AREA" --csv
}

cmd_backtest_horizon() {
    parse_flags "$@"
    python -m scripts.run_backtest_horizon --days "$DAYS" --horizon "$HORIZON" --area "$AREA" --train-days "$TRAIN_DAYS"
}

cmd_ablation_gas() {
    parse_flags "$@"
    python -m scripts.ablation_gas --days "$DAYS" --area "$AREA"
}

cmd_smoke() {
    python scripts/fetch_prices_smoke.py
}

cmd_test() {
    pytest tests/ -v
}

cmd_lambda_backfill() {
    parse_flags "$@"
    aws lambda invoke --function-name unagi-scheduler \
        --payload "{\"backfill_days\": $DAYS}" \
        --cli-binary-format raw-in-base64-out /dev/stdout
}

cmd_lambda_collect() {
    aws lambda invoke --function-name unagi-scheduler \
        --payload '{"midnight_collect": true}' \
        --cli-binary-format raw-in-base64-out /dev/stdout
}

cmd_lambda_predict() {
    parse_flags "$@"
    if [[ -n "${TARGET_DATE:-}" ]]; then
        aws lambda invoke --function-name unagi-scheduler \
            --payload "{\"predict_only\": true, \"target_date\": \"$TARGET_DATE\"}" \
            --cli-binary-format raw-in-base64-out /dev/stdout
    else
        aws lambda invoke --function-name unagi-scheduler \
            --payload '{"predict_only": true}' \
            --cli-binary-format raw-in-base64-out /dev/stdout
    fi
}

# ── Help ─────────────────────────────────────────────────────
cmd_help() {
    cat <<'EOF'
unagi — Unagi CLI 🐟

Usage: ./unagi <command> [flags]

Data:
  fetch                         Fetch today + tomorrow spot prices
  backfill [--days N] [--area]  Backfill spot prices (default: 30 days, SE3)
  backfill-gen [--days N]       Backfill generation mix
  backfill-load [--days N]      Backfill load forecast (A65)
  backfill-de [--days N]        Backfill DE-LU spot prices (A44)
  backfill-gas [--days N]       Backfill THE gas reference prices
  backfill-bal [--days N]       Backfill balancing/imbalance prices (eSett)

ML:
  backtest [--days N] [--area]  LightGBM vs baseline comparison
  backtest-horizon [--days N] [--horizon H] [--train-days T]
                                Multi-horizon backtest (d+1..d+H, recursive)
  ablation-gas [--days N]       Gas feature ON/OFF comparison (A/B test)
  sweep [--days N] [--area]     Training window size optimization
  tune [--trials N] [--area]    Optuna hyperparameter tuning
  features [--days N] [--area]  Build feature matrix (CSV to stdout)

Diagnostics:
  smoke                         ENTSO-E API connectivity check
  test                          Run pytest suite

Lambda (requires AWS credentials):
  lambda-backfill [--days N]    Invoke scheduler Lambda for backfill
  lambda-collect                Data collection only (generation, balancing, etc.)
  lambda-predict [--date D]     Prediction-only run (default: tomorrow)

Flags:
  --days N      Number of days (default: 30)
  --area CODE   Price area SE1-SE4 (default: SE3)
  --trials N    Optuna trials (default: 100)
  --date D      Target date YYYY-MM-DD (lambda-predict only)
  --horizon H   Max forecast horizon (default: 3, backtest-horizon only)
  --train-days T Training window days (default: 270, backtest-horizon only)
EOF
}

# ── Dispatch ─────────────────────────────────────────────────
command="${1:-help}"
shift || true

case "$command" in
    fetch)          cmd_fetch "$@" ;;
    backfill)       cmd_backfill "$@" ;;
    backfill-gen)   cmd_backfill_gen "$@" ;;
    backfill-load)  cmd_backfill_load "$@" ;;
    backfill-de)    cmd_backfill_de "$@" ;;
    backfill-gas)   cmd_backfill_gas "$@" ;;
    backfill-bal)   cmd_backfill_bal "$@" ;;
    backtest)       cmd_backtest "$@" ;;
    backtest-horizon) cmd_backtest_horizon "$@" ;;
    ablation-gas)   cmd_ablation_gas "$@" ;;
    sweep)          cmd_sweep "$@" ;;
    tune)           cmd_tune "$@" ;;
    features)       cmd_features "$@" ;;
    smoke)          cmd_smoke ;;
    test)           cmd_test ;;
    lambda-backfill) cmd_lambda_backfill "$@" ;;
    lambda-collect)  cmd_lambda_collect ;;
    lambda-predict)  cmd_lambda_predict "$@" ;;
    help|--help|-h)  cmd_help ;;
    *)
        echo "Unknown command: $command" >&2
        echo "Run './unagi help' for usage." >&2
        exit 1
        ;;
esac
